# Database
DATABASE_URL=postgresql+asyncpg://resume_agent:resume_agent_dev@localhost:5432/resume_agent

# Vector DB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=resume_agent_

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM APIs
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Default LLM models
DEFAULT_TAILOR_MODEL=claude-3-5-sonnet-20241022
DEFAULT_PARSER_MODEL=gpt-4o
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large

# Application
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate Limiting
MAX_DAILY_APPLICATIONS=20
MAX_DAILY_EMAILS=10
